# =========================================
# Stream Recorder 환경 변수 설정 파일 템플릿
# =========================================
# 이 파일을 .env 로 복사한 뒤 각 값을 입력하세요.

# 텔레그램 알림 설정 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 출력 디렉토리 (기본값: ./output)
OUTPUT_DIR=./output

# 디버그 모드 (True/False)
DEBUG=False

# Streamlink / FFmpeg 커스텀 경로 (기본값: PATH에서 탐색)
STREAMLINK_PATH=streamlink
FFMPEG_PATH=ffmpeg

# Rclone 클라우드 업로드 설정 (선택)
RCLONE_PATH=rclone
RCLONE_REMOTE=

# API 인증 키 (빈 값이면 인증 비활성화 = 개발 모드)
API_KEY=
